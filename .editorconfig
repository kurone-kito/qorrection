root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

# Rust formatting follows `rustfmt` defaults (4-space indent),
# which differs from the project-wide 2-space rule.
[*.rs]
indent_size = 4
